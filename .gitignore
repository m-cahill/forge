# FORGE .gitignore

# =============================================================================
# Local reference documentation (not FORGE deliverables)
# =============================================================================
docs/enhancements/
docs/manuals/
docs/prompts/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
ENV/
env/
.conda/

# =============================================================================
# IDE and editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# Jupyter / notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# ML / Training artifacts (large files - use manifests instead)
# =============================================================================
*.zip
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.h5
*.onnx

# =============================================================================
# Data artifacts (track manifests, not raw data)
# =============================================================================
data/raw/*
!data/raw/.gitkeep
data/external/*
!data/external/.gitkeep
data/generated/*
!data/generated/.gitkeep
*.parquet
*.arrow

# =============================================================================
# Artifacts directory (runs tracked via manifests in docs/forge.md)
# =============================================================================
artifacts/runs/*/
!artifacts/runs/.gitkeep

# =============================================================================
# Submissions (sensitive - track hashes in docs/forge.md instead)
# =============================================================================
submissions/*/
!submissions/.gitkeep

# =============================================================================
# Environment and secrets
# =============================================================================
.env
.env.*
*.pem
credentials.json
secrets.yaml
secrets.json

# =============================================================================
# OS generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Logs and temporary files
# =============================================================================
*.log
logs/
tmp/
temp/
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# =============================================================================
# Coverage and test artifacts
# =============================================================================
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.nox/
.tox/
